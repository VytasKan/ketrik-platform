{
	"tenantId": "ketrik-web",
	"version": "1.0.0",
	"stores": {
		"global": {
			"strategy": "FETCH",
			"options": {
				"url": "/api/files/globals.json"
			}
		},

		"private": {
			"strategy": "FIRESTORE",
			"options": {
				"path": "registers",
				"isSnapshot": true,
				"asObject": true
			}
		},
		"profile": {
			"strategy": "FIRESTORE",
			"options": {
				"path": "users/${uid}",
				"isSnapshot": true,
				"asObject": false
			}
		},
		"notifications": {
			"strategy": "FIRESTORE",
			"options": {
				"path": "channels",
				"isSnapshot": true,
				"asObject": false
			}
		}
	}
}
